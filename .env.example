# ===== OpenAI(GPT) API 설정 =====
# 1) https://platform.openai.com 에서 API 키를 발급받아 아래에 넣으세요.
#    (이 파일을 복사해 .env 로 만든 뒤 실제 키를 입력합니다. .env 는 절대 깃에 올리지 않습니다.)
OPENAI_API_KEY=sk-여기에_본인_키를_넣으세요

# 2) 사용할 모델. 비용/성능에 따라 선택하세요.
#    기본값은 gpt-5.4-mini 입니다. (GPT-5 mini 계열은 temperature 미지원,
#    토큰 한도는 max_completion_tokens 로 지정 — 코드에서 이미 처리됨)
#    최신 모델명과 단가는 platform.openai.com/docs/models 에서 확인 후 교체하세요.
OPENAI_MODEL=gpt-5.4-mini

# 3) (선택) OpenAI 조직/프로젝트 분리 운영 시에만 입력하세요. 없으면 비워 둡니다.
# OPENAI_ORG_ID=org-xxxxxxxxxxxxxxxxxxxxx
# OPENAI_PROJECT_ID=proj_xxxxxxxxxxxxxxxxxxxxx
